        h2 { margin-top: 30px; margin-bottom: 12px; font-size: 18px; font-weight: 800; color: var(--mario-navy); text-transform: uppercase; letter-spacing: 1px; }
        p { line-height: 1.7; margin-bottom: 15px; color: #4A5568; font-size: 15px; }
        .btn-back { display: flex; align-items: center; justify-content: center; gap: 10px; margin-top: 40px; padding: 15px 30px; background: var(--mario-navy); color: white; text-decoration: none; border-radius: 12px; font-weight: 800; text-transform: uppercase; transition: 0.3s; }

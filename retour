        body { background-color: var(--mario-light); color: var(--mario-navy); padding: 40px 20px; display: flex; justify-content: center; align-items: center; min-height: 100vh; }
        .container { max-width: 800px; width: 100%; background: white; padding: 50px; border-radius: 20px; box-shadow: 0 15px 40px rgba(0,0,0,0.08); border-top: 5px solid var(--mario-orange); }
